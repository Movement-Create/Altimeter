{
  "name": "altimeter-vscode",
  "displayName": "Altimeter",
  "description": "AI agent orchestrator for VS Code — chat, run prompts, explain and fix code",
  "version": "0.1.0",
  "publisher": "altimeter",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "icon": "resources/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/altimeter/vscode-extension"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "altimeter-sidebar",
          "title": "Altimeter",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "altimeter-sidebar": [
        {
          "type": "webview",
          "id": "altimeter.chatView",
          "name": "Chat",
          "icon": "resources/icon.svg",
          "contextualTitle": "Altimeter"
        }
      ]
    },
    "commands": [
      {
        "command": "altimeter.openChat",
        "title": "Open Chat",
        "category": "Altimeter",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "altimeter.runPrompt",
        "title": "Run Prompt",
        "category": "Altimeter",
        "icon": "$(play)"
      },
      {
        "command": "altimeter.runOnSelection",
        "title": "Run on Selection",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.explainSelection",
        "title": "Explain Selection",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.fixSelection",
        "title": "Fix Selection",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.listTools",
        "title": "List Tools",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.listSessions",
        "title": "List Sessions",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.addMemory",
        "title": "Add Memory",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.searchMemory",
        "title": "Search Memory",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.explainInChat",
        "title": "Altimeter: Explain",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.fixInChat",
        "title": "Altimeter: Fix",
        "category": "Altimeter"
      },
      {
        "command": "altimeter.askAltimeter",
        "title": "Altimeter: Ask Altimeter",
        "category": "Altimeter"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "altimeter.explainInChat",
          "when": "editorHasSelection",
          "group": "altimeter@1"
        },
        {
          "command": "altimeter.fixInChat",
          "when": "editorHasSelection",
          "group": "altimeter@2"
        },
        {
          "command": "altimeter.askAltimeter",
          "when": "editorHasSelection",
          "group": "altimeter@3"
        }
      ]
    },
    "keybindings": [
      {
        "command": "altimeter.openChat",
        "key": "ctrl+shift+a",
        "mac": "cmd+shift+a"
      },
      {
        "command": "altimeter.runPrompt",
        "key": "ctrl+shift+r",
        "mac": "cmd+shift+r"
      }
    ],
    "configuration": {
      "title": "Altimeter",
      "properties": {
        "altimeter.provider": {
          "type": "string",
          "default": "google",
          "enum": [
            "anthropic",
            "openai",
            "google",
            "ollama"
          ],
          "description": "Default AI provider"
        },
        "altimeter.model": {
          "type": "string",
          "default": "gemini-2.5-flash",
          "description": "Default model name"
        },
        "altimeter.maxTurns": {
          "type": "number",
          "default": 10,
          "description": "Default maximum number of agent turns"
        },
        "altimeter.maxBudget": {
          "type": "number",
          "default": 1.0,
          "description": "Default maximum budget in USD"
        },
        "altimeter.autoApprove": {
          "type": "boolean",
          "default": true,
          "description": "Auto-approve tool permissions"
        },
        "altimeter.googleApiKey": {
          "type": "string",
          "default": "",
          "description": "Google API key for Gemini models",
          "markdownDescription": "Google API key. Get yours at [aistudio.google.com](https://aistudio.google.com)"
        },
        "altimeter.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude models",
          "markdownDescription": "Anthropic API key. Get yours at [console.anthropic.com](https://console.anthropic.com)"
        },
        "altimeter.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API key for GPT models",
          "markdownDescription": "OpenAI API key. Get yours at [platform.openai.com](https://platform.openai.com)"
        },
        "altimeter.altimeterPath": {
          "type": "string",
          "default": "",
          "description": "Path to Altimeter installation directory (leave blank for auto-detect)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "ts-loader": "^9.0.0",
    "typescript": "^5.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  }
}
